---
import { getCollection } from "astro:content";
import { format } from "date-fns";
import { es } from "date-fns/locale";

interface Props {
    projectSlug: string;
}

const { projectSlug } = Astro.props;

// Obtener entradas de la bitácora para este proyecto
const allJournalEntries = (await getCollection("journal" as any)) as any[];
const entries = allJournalEntries
    .filter((entry) => entry.data?.project === projectSlug && entry.data?.published)
    .sort((a, b) => (b.data?.date?.valueOf() || 0) - (a.data?.date?.valueOf() || 0));

if (entries.length === 0) return null;
---

<section class="mt-20 pt-10 border-t border-border/50">
    <div class="flex items-center gap-4 mb-12">
        <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
        </div>
        <div>
            <h2 class="text-3xl font-black font-heading tracking-tight">Bitácora de Desarrollo</h2>
            <p class="text-sm text-text/60 font-medium">El proceso detrás de este proyecto</p>
        </div>
    </div>

    <div class="relative pl-8 md:pl-12 border-l-2 border-primary/20 space-y-12 ml-4">
        {
            entries.map((entry, index) => (
                <div class="journal-entry relative" data-index={index}>
                    {/* Dot on timeline */}
                    <div class="absolute -left-[41px] md:-left-[53px] top-1 w-4 h-4 rounded-full bg-background border-4 border-primary z-10 shadow-[0_0_0_4px_rgba(var(--color-primary-rgb),0.1)]" />
                    
                    <div class="flex flex-col gap-2">
                        <time class="text-xs font-bold uppercase tracking-widest text-primary/70">
                            {entry.data?.date ? format(entry.data.date, "dd 'de' MMMM, yyyy", { locale: es }) : ''}
                        </time>
                        
                        <h3 class="text-xl md:text-2xl font-bold font-heading hover:text-primary transition-colors">
                            <a href={`/proyectos/${projectSlug}/diario/${entry.id.split('/').pop()?.replace(/\.(md|mdx)$/, "")}`}>
                                {entry.data.title}
                            </a>
                        </h3>
                        
                        {entry.data?.description && (
                            <p class="text-text/80 leading-relaxed max-w-2xl">
                                {entry.data.description}
                            </p>
                        )}
                        
                        <div class="mt-4">
                            <a 
                                href={`/proyectos/${projectSlug}/diario/${entry.id.split('/').pop()?.replace(/\.(md|mdx)$/, "")}`}
                                class="inline-flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all"
                            >
                                Seguir leyendo
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const entries = document.querySelectorAll(".journal-entry");
    
    entries.forEach((entry) => {
        gsap.from(entry, {
            scrollTrigger: {
                trigger: entry,
                start: "top 85%",
                toggleActions: "play none none none"
            },
            opacity: 0,
            x: -20,
            duration: 0.8,
            ease: "power3.out"
        });
    });
</script>

<style>
    .journal-entry {
        will-change: transform, opacity;
    }
</style>
