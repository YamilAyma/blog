---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
    post: any; // Usamos any para permitir múltiples colecciones
    variant?: "large" | "small" | "wide";
    postId?: string;
}

const { post, variant = "small" } = Astro.props;

// Determinar la URL base según la colección
const collection = post.collection;
let baseUrl = "/blog/";
if (collection === "posts") baseUrl = "/posts/";
if (collection === "journal") {
    // Para journal, necesitamos el proyecto asociado
    const projectRef = post.data.project;
    const projectSlug = typeof projectRef === 'string' 
        ? projectRef.replace(/\.(md|mdx)$/, "") 
        : projectRef.id.replace(/\.(md|mdx)$/, "");
    baseUrl = `/proyectos/${projectSlug}/diario/`;
}

// Usar el slug de Astro o el ID relativo completo (preservando subfolders como 'automatizacion/')
const slug = post.slug || post.id.replace(/\.(md|mdx)$/, "");
const href = `${baseUrl}${slug}`;

const image = post.data.image;
const imageAlt = post.data.title;
const textContent = post.data.description || post.data.copy || "";

// Truncar copy a un número de palabras según variante
const maxWords = variant === "large" ? 25 : variant === "wide" ? 20 : 12;
const truncatedCopy =
    textContent.split(" ").slice(0, maxWords).join(" ") +
    (textContent.split(" ").length > maxWords ? "..." : "");
---

<a
    href={href}
    class={`post-card group block no-underline overflow-hidden rounded-[1.5rem] bg-background border border-black/5 dark:border-white/5 transition-all duration-300`}
    aria-label={`Leer ${post.data.title}`}
>
    <div class="flex flex-col h-full">
        {image && (
            <div class="relative aspect-video overflow-hidden border-b border-black/5 dark:border-white/5">
                {typeof image === "string" ? (
                    <img
                        src={image}
                        alt={imageAlt || ""}
                        class="w-full h-full object-cover transition-transform duration-500"
                        loading="lazy"
                    />
                ) : (
                    <Image 
                        src={image} 
                        alt={imageAlt || ""} 
                        class="w-full h-full object-cover transition-transform duration-500" 
                    />
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>
            </div>
        )}

        <div class="p-5 flex flex-col flex-grow gap-3">
            <h3 class="text-lg font-black font-heading leading-tight m-0  line-clamp-2 transition-colors text-md-h1">
                {post.data.title}
            </h3>
            
            {truncatedCopy && (
                <p class="text-sm text-stone-secondary/20 m-0 line-clamp-2 leading-relaxed italic">
                    {truncatedCopy}
                </p>
            )}

            <div class="flex items-center justify-between mt-auto pt-2">
                {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.slice(0, 2).map((tag: string) => (
                            <span class="px-2 py-0.5 bg-primary/10 text-primary rounded text-[9px] font-bold uppercase tracking-wider">
                                #{tag}
                            </span>
                        ))}
                    </div>
                )}
                
                <div class="text-primary opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0 duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14m-7-7 7 7-7 7"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</a>

<style>
    .post-card {
        cursor: pointer;
    }
</style>
