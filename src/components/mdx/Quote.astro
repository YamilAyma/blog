---
interface Props {
  cite?: string;
  role?: string;
  url?: string;
}

const { cite, role, url } = Astro.props;
---

<blockquote class="quote-card my-12 p-8 rounded-2xl relative group animate-in fade-in duration-700 border">
  <!-- Icono de Comillas -->
  <div class="mb-4 text-amber-600/60 dark:text-amber-500/60">
    <svg  class="w-10 h-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M6.776 10.335a7.015 7.015 0 0 1 1.986-1.828L9 8.36V6.437l-.593.113C2.31 7.7 2 12.646 2 13.625 2 15.732 3.251 18 5.997 18A3.856 3.856 0 0 0 10 14.121a3.906 3.906 0 0 0-3.224-3.786zM5.997 17C3.785 17 3 15.182 3 13.625c0-1.135.372-4.807 5-5.963v.146a7.985 7.985 0 0 0-2.521 2.695l-.338.747H6a2.941 2.941 0 0 1 3 2.871A2.878 2.878 0 0 1 5.997 17zm12.78-6.665a7.015 7.015 0 0 1 1.985-1.828L21 8.36V6.437l-.593.113C14.31 7.7 14 12.646 14 13.625 14 15.732 15.251 18 17.997 18A3.856 3.856 0 0 0 22 14.121a3.906 3.906 0 0 0-3.224-3.786zM17.996 17C15.785 17 15 15.182 15 13.625c0-1.135.372-4.807 5-5.963v.146a7.985 7.985 0 0 0-2.521 2.695l-.338.747H18a2.941 2.941 0 0 1 3 2.871A2.878 2.878 0 0 1 17.997 17z"></path><path fill="none" d="M0 0h24v24H0z"></path></g></svg>
  </div>

  <div class="relative z-10">
    <div class="text-lg md:text-xl font-bold text-stone-800 dark:text-stone-100  mb-6 font-body">
      <slot />
    </div>

    {(cite || role) && (
      <footer class="flex flex-col items-end text-right mt-4">
        <div class="flex items-center gap-2">
          <span class="text-stone-400">—</span>
          {url ? (
            <a href={url} target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-stone-700 dark:text-stone-200 hover:text-primary transition-colors">
              {cite}
            </a>
          ) : (
            <span class="text-sm font-bold text-stone-700 dark:text-stone-200">
              {cite}
            </span>
          )}
        </div>
        {role && (
          <span class="text-xs text-stone-500 dark:text-stone-400 mt-1 italic">
            {role}
          </span>
        )}
      </footer>
    )}
  </div>
</blockquote>

<style>
    .quote-card {
        box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.05);
    }
</style>
