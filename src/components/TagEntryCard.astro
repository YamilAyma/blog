---
/**
 * TagEntryCard.astro - Tarjeta universal para mostrar resultados de búsqueda por etiquetas.
 * Se adapta según el tipo de contenido (blog, proyecto, post visual, bitácora).
 */
import { Image } from "astro:assets";

interface Props {
    entry: any; // La entrada de la colección
    collection: "blog" | "projects" | "posts" | "journal";
}

const { entry, collection } = Astro.props;
const { data, id } = entry;

// Lógica de rutas
let href = "";
let typeLabel = "";
let typeColor = "";

const slug = id.replace(/\.(md|mdx)$/, "");

switch (collection) {
    case "blog":
        href = `/blog/${slug}`;
        typeLabel = "Artículo";
        typeColor = "#3b82f6"; // Blue
        break;
    case "projects":
        href = `/proyectos/${slug}`;
        typeLabel = "Proyecto";
        typeColor = "#10b981"; // Green
        break;
    case "posts":
        href = `/posts/${slug}`;
        typeLabel = "Post Visual";
        typeColor = "#f59e0b"; // Amber
        break;
    case "journal":
        href = `/proyectos/${data.project}/diario/${slug.split('/').pop()}`;
        typeLabel = "Bitácora";
        typeColor = "#8b5cf6"; // Purple
        break;
}

const title = data.title || data.copy || "Sin título";
const description = data.description || data.copy || "Ver más...";
const date = data.date;
const image = data.image;
---

<a href={href} class="group block no-underline">
    <article class="bg-gradient-to-r from-primary/50 to-secondary/50 dark:bg-stone-900/50 border border-black/5 dark:border-white/10 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col h-full">
        <!-- Imagen -->
        {image && (
            <div class="aspect-video overflow-hidden bg-stone-100 dark:bg-stone-800">
                {typeof image === "string" ? (
                    <img 
                        src={image} 
                        alt={title} 
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                ) : (
                    <Image 
                        src={image} 
                        alt={title} 
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                )}
            </div>
        )}

        <div class="p-5 flex flex-col flex-grow">
            <!-- Label de Tipo -->
            <span 
                class="inline-block text-[10px] font-black uppercase tracking-widest mb-3 px-2 py-0.5 rounded-md self-start"
                style={`background-color: ${typeColor}20; color: ${typeColor};`}
            >
                {typeLabel}
            </span>

            <h3 class="text-lg font-bold leading-tight mb-2">
                {title}
            </h3>

            <p class="text-sm text-md-4 dark:text-stone-400 line-clamp-2 mb-4">
                {description}
            </p>

            <div class="mt-auto flex items-center justify-between">
                {date && (
                    <time class="text-[10px] font-mono opacity-50 uppercase tracking-wider">
                        {date.toLocaleDateString("es-ES", {
                            year: "numeric",
                            month: "short",
                            day: "numeric",
                        })}
                    </time>
                )}
                <span class="text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity translate-x-2 group-hover:translate-x-0 duration-300">
                    Leer más &rarr;
                </span>
            </div>
        </div>
    </article>
</a>
