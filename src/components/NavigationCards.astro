---
/**
 * NavigationCards - Componente reutilizable que agrupa las 4 tarjetas de navegación
 * principales (Portafolio, Posts, Proyectos, Contacto).
 */
import HoverImage from "./HoverImage.astro";
import cardPortafolio from "../assets/images/cards/portafolio.png";
import portfolioWebp from "../assets/images/cards/animated/portafolio.webp";
import cardPost from "../assets/images/cards/post.png";
import postWebp from "../assets/images/cards/animated/post.webp"
import cardProyectos from "../assets/images/cards/proyectos.png";
import proyectosWebp from "../assets/images/cards/animated/proyectos.webp"
import cardRedes from "../assets/images/cards/redes.png";
import redesWebp from "../assets/images/cards/animated/redes.webp"
import cardCV from "../assets/images/cards/cv.png";
import cvWebp from "../assets/images/cards/animated/cv.webp"
import cardTags from "../assets/images/cards/tags.png";
import tagsWebp from "../assets/images/cards/animated/tags.webp"


export interface Props {
    gridClass?: string;
}

const { gridClass = "grid grid-cols-1 md:grid-cols-2 gap-6" } = Astro.props;
---

<div class={gridClass} id="nav-cards-grid">
    <a href="/portafolio" class="nav-card group block relative overflow-hidden rounded-[2rem] bg-white border-[4.5px] border-white shadow-lg hover:shadow-xl transition-all duration-500">
        <HoverImage 
            staticSrc={cardPortafolio} 
            hoverSrc={portfolioWebp}
            alt="Portafolio" 
        />
    </a>
    <a href="/posts" class="nav-card group block relative overflow-hidden rounded-[2rem] bg-white border-[4.5px] border-white shadow-lg hover:shadow-xl transition-all duration-500">
        <HoverImage 
            staticSrc={cardPost} 
            hoverSrc={postWebp}
            alt="Posts Visuales" 
        />
    </a>
    <a href="/proyectos" class="nav-card group block relative overflow-hidden rounded-[2rem] bg-white border-[4.5px] border-white shadow-lg hover:shadow-xl transition-all duration-500">
        <HoverImage 
            staticSrc={cardProyectos} 
            hoverSrc={proyectosWebp}
            alt="Proyectos" 
        />
    </a>
    <a href="/contacto" class="nav-card group block relative overflow-hidden rounded-[2rem] bg-white border-[4.5px] border-white shadow-lg hover:shadow-xl transition-all duration-500">
        <HoverImage 
            staticSrc={cardRedes} 
            hoverSrc={redesWebp}
            alt="Redes y Contacto" 
        />
    </a>
    <a 
        href="https://github.com/YamilAyma/cv/releases/download/latest/Anthony_Yamil_Ayma_Leon_CV.pdf" 
        target="_blank" 
        rel="noopener noreferrer"
        class="nav-card group block relative overflow-hidden rounded-[2rem] bg-white border-[4.5px] border-white shadow-lg hover:shadow-xl transition-all duration-500 md:col-span-2 lg:col-span-1"
    >
        <HoverImage 
            staticSrc={cardCV} 
            hoverSrc={cvWebp}
            alt="Descargar mi CV" 
        />
    </a>
    <a href="/tags" class="nav-card group block relative overflow-hidden rounded-[2rem] bg-white border-[4.5px] border-white shadow-lg hover:shadow-xl transition-all duration-500">
        <HoverImage 
            staticSrc={cardTags} 
            hoverSrc={tagsWebp}
            alt="Etiquetas" 
        />
    </a>
</div>

<script>
    import { gsap } from "gsap";

    const initCards = () => {
        const cards = document.querySelectorAll(".nav-card");
        if (cards.length > 0) {
            cards.forEach(card => {
                card.addEventListener("mouseenter", () => {
                    gsap.to(card, {
                        y: -6,
                        scale: 1.01,
                        duration: 0.3,
                        ease: "power2.out"
                    });
                });
                card.addEventListener("mouseleave", () => {
                    gsap.to(card, {
                        y: 0,
                        scale: 1,
                        duration: 0.3,
                        ease: "power2.inOut"
                    });
                });
            });
        }
    };

    // Inicializar y manejar transiciones si es necesario
    initCards();
    document.addEventListener("astro:page-load", initCards);
</script>

<style>
    :global(.dark) .nav-card {
        background-color: #fff;
    }
</style>
