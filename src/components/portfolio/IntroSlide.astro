<section
    id="intro"
    class="portfolio-slide h-screen w-full flex flex-col items-center justify-center p-6 md:p-20 relative overflow-hidden"
>
    <div class="slide-content text-center z-10 pt-20 md:pt-0">
        <h1
            class="text-4xl sm:text-6xl md:text-8xl font-bold font-heading mb-6 opacity-0 translate-y-10 leading-tight"
            id="intro-title"
        >
            ¡Hola, soy Yamil!
        </h1>
        <p
            class="text-lg sm:text-xl md:text-2xl max-w-2xl mx-auto opacity-0 translate-y-10"
            id="intro-description"
        >
            Bienvenido a mi universo digital. Desliza para explorar mis
            proyectos, ideas y más.
        </p>
    </div>

    <!-- Background elements for animation -->
    <div
        class="absolute top-1/4 left-1/4 w-32 h-32 bg-primary/20 rounded-full blur-3xl"
        id="blob-1"
    >
    </div>
    <div
        class="absolute bottom-1/4 right-1/4 w-48 h-48 bg-accent/20 rounded-full blur-3xl"
        id="blob-2"
    >
    </div>
</section>

<style>
    .portfolio-slide {
        background-color: var(--color-background);
        color: var(--color-text);
    }
</style>
