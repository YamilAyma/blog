---
import { SITE, SOCIALS } from "../../config";

/**
 * IntroSlide - Sección de bienvenida del portafolio.
 * Incluye: Foto de perfil dinámica, Título principal, Descripción,
 * Botones de acción dual, Redes Sociales y Fondo Animado de Cuadrados.
 */

const profileImage =
    SITE.imgProfile || "https://avatars.githubusercontent.com/u/177412646";
---

<section
    id="intro"
    class="portfolio-slide w-full flex flex-col items-center justify-center p-4 relative overflow-hidden"
>
    <!-- Background Decoration: Animated Squares -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <div class="floating-square sq-1"></div>
        <div class="floating-square sq-2"></div>
        <div class="floating-square sq-3"></div>
        <div class="floating-square sq-4"></div>
        <div class="floating-square sq-5"></div>
        <div class="floating-square sq-6"></div>
    </div>

    <div
        class="slide-content text-center z-10 max-w-4xl mx-auto flex flex-col items-center py-8"
    >
        <!-- Profile Image from Config -->
        <div
            class="profile-img-container mb-6 w-36 h-36 md:w-48 md:h-48 rounded-full border-4 border-primary/20 p-1.5 opacity-0 translate-y-10 transition-all duration-700 hover:border-primary/40"
            id="intro-profile"
        >
            <div
                class="w-full h-full rounded-full overflow-hidden bg-stone-200 dark:bg-stone-800 flex items-center justify-center relative group shadow-inner"
            >
                <img
                    src={profileImage}
                    alt={`Foto de perfil de ${SITE.author}`}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div
                    class="hidden absolute inset-0 text-stone-400 font-bold text-center p-3 items-center justify-center text-xs md:text-sm"
                >
                    <h1 class="font-heading">{SITE.author}</h1>
                </div>
            </div>
        </div>

        <!-- Title & Subtitle -->
        <div class="text-group mb-4">
            <h1
                class="text-4xl sm:text-6xl md:text-7xl font-black font-heading tracking-tighter opacity-0 translate-y-10 leading-none"
                id="intro-name"
                style="color: var(--md-h1);"
            >
                {SITE.author}
            </h1>
            <h2
                class="text-xl sm:text-2xl md:text-3xl font-bold font-heading text-text opacity-0 translate-y-10 mt-2 leading-tight"
                id="intro-role"
            >
                <span style="color: var(--md-h6);">Desarrollador Web y</span> <span style="color: var(--md-h1);"
                    >Creador de Experiencias.</span
                >
            </h2>
        </div>

        <!-- Description -->
        <p
            class="text-base sm:text-lg max-w-xl mx-auto opacity-0 translate-y-10 mb-8 text-text/80 leading-relaxed px-4"
            id="intro-description"
        >
            {SITE.description.split(".")[0]}. Descubre mi trabajo y cómo puedo
            ayudarte.
        </p>

        <!-- Dual CTA Button -->
        <div
            class="dual-cta-container flex items-center bg-white/30 dark:bg-black/20 backdrop-blur-md p-1 rounded-full border border-white/40 shadow-xl opacity-0 translate-y-10 mb-8 scale-90 sm:scale-100"
            id="intro-cta"
        >
            <a
                href="#projects"
                class="cta-secondary px-5 py-2 rounded-full text-xs font-bold tracking-wide transition-all duration-300 hover:brightness-110 hover:shadow-lg active:scale-95 text-center"
                style="background-color: var(--ui-nav-link); color: white;"
            >
                Ver Proyectos
            </a>
            <a
                href="#contact"
                class="cta-primary px-7 py-2 rounded-full text-xs font-bold tracking-wide transition-all duration-300 hover:brightness-110 hover:shadow-lg active:scale-95 text-center"
                style="background-color: var(--md-h1); color: white;"
            >
                Contáctame
            </a>
        </div>

        <!-- Social Icons Dynamic from Config -->
        <div
            class="social-icons flex items-center gap-5 opacity-0 translate-y-10"
            id="intro-socials"
        >
            {
                SOCIALS.map((social) => (
                    <a
                        href={social.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="social-link text-text/60 hover:text-primary transition-all duration-300 hover:scale-125"
                        aria-label={social.name}
                    >
                        {social.icon === "github" && (
                            <svg
                                class="w-5 h-5"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                            </svg>
                        )}
                        {social.icon === "linkedin" && (
                            <svg
                                class="w-5 h-5"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                            </svg>
                        )}
                        {social.icon === "mail" && (
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                />
                            </svg>
                        )}
                        {social.icon === "pinterest" && (
                            <svg
                                class="w-5 h-5"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.411-5.97 1.411-5.97s-.36-.723-.36-1.781c0-1.667.967-2.912 2.168-2.912 1.024 0 1.517.769 1.517 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.008 2.352-1.497 3.146 1.122.341 2.308.526 3.54.526 6.615 0 12.019-5.373 12.019-12.018 0-6.645-5.374-12.017-12.02-12.017" />
                            </svg>
                        )}
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .portfolio-slide {
        background-color: transparent;
        min-height: 100vh;
        z-index: 1;
        overflow: hidden;
    }

    .profile-img-container {
        box-shadow: 0 15px 40px -10px rgba(0, 0, 0, 0.12);
    }

    .dual-cta-container {
        box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.15);
    }

    .social-link svg {
        filter: drop-shadow(0 0 6px rgba(0, 0, 0, 0.03));
    }

    /* Floating Squares Styles */
    .floating-square {
        position: absolute;
        background-color: var(--md-h1);
        opacity: 0.2;
        border-radius: 2rem;
        z-index: -1;
        animation: float 20s infinite linear;
    }

    .dark .floating-square {
        opacity: 0.08;
    }

    .sq-1 {
        width: 300px;
        height: 300px;
        top: -10%;
        left: -5%;
        animation-duration: 25s;
        filter: blur(40px);
    }
    .sq-2 {
        width: 200px;
        height: 200px;
        top: 60%;
        right: -5%;
        background-color: var(--color-accent);
        animation-duration: 30s;
        filter: blur(30px);
        animation-direction: reverse;
    }
    .sq-3 {
        width: 150px;
        height: 150px;
        bottom: 10%;
        left: 15%;
        animation-duration: 22s;
        filter: blur(20px);
    }
    .sq-4 {
        width: 250px;
        height: 250px;
        top: 15%;
        right: 10%;
        background-color: var(--color-accent);
        animation-duration: 28s;
        filter: blur(50px);
    }
    .sq-5 {
        width: 100px;
        height: 100px;
        top: 40%;
        left: 10%;
        animation-duration: 18s;
        filter: blur(15px);
        animation-direction: reverse;
    }
    .sq-6 {
        width: 180px;
        height: 180px;
        bottom: -5%;
        right: 20%;
        animation-duration: 35s;
        filter: blur(35px);
    }

    @keyframes float {
        0% {
            transform: translate(0, 0) rotate(0deg) scale(1);
        }
        33% {
            transform: translate(30px, -50px) rotate(10deg) scale(1.05);
        }
        66% {
            transform: translate(-20px, 20px) rotate(-10deg) scale(0.95);
        }
        100% {
            transform: translate(0, 0) rotate(0deg) scale(1);
        }
    }
</style>
