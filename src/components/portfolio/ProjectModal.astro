---
/**
 * ProjectModal.astro - Modal premium para detalles de proyecto.
 * Refinado: Sizing corregido, sincronización con tema global y soporte para badges.
 * Layout: Tecnologías debajo de la imagen (Carousel).
 */
interface Props {}
---

<div
    id="project-modal-overlay"
    class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 md:p-10 pointer-events-none"
>
    <!-- Glassmorphism Backdrop -->
    <div
        class="absolute inset-0 bg-background/60 backdrop-blur-2xl opacity-0"
        id="modal-backdrop"
    >
    </div>

    <!-- Modal Card -->
    <div
        class="relative w-full max-w-6xl rounded-[2.5rem] shadow-2xl overflow-hidden border border-border opacity-0 scale-95 pointer-events-auto flex flex-col md:flex-row max-h-[85vh] md:max-h-[90vh] overflow-y-auto md:overflow-hidden"
        style="background-color: var(--color-background);"
        id="modal-card"
    >
        <!-- Close Button -->
        <button
            id="modal-close"
            class="absolute top-4 right-4 md:top-6 md:right-6 z-50 w-9 h-9 md:w-10 md:h-10 flex items-center justify-center rounded-full text-text/60 hover:text-text transition-all shadow-md group border border-border backdrop-blur-md"
            style="background-color: var(--color-background);"
            aria-label="Cerrar modal"
        >
            <svg
                class="w-5 h-5 group-hover:rotate-90 transition-transform duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <!-- Left Column: Carousel & Tech (60%) -->
        <div class="w-full md:w-3/5 flex flex-col flex-shrink-0">
            <!-- Carousel Container (Compact on mobile) -->
            <div
                class="relative h-[180px] sm:h-[220px] md:h-auto md:aspect-[16/9] w-full overflow-hidden bg-primary/5"
            >
                <div id="modal-carousel" class="absolute inset-0 flex h-full">
                    <!-- Slides will be injected here -->
                </div>
                <!-- Progress Overlay -->
                <div
                    class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-1.5 z-20"
                    id="modal-carousel-dots"
                >
                </div>
                <!-- Inner Shadow -->
                <div
                    class="absolute inset-0 pointer-events-none shadow-[inset_0_0_60px_rgba(0,0,0,0.05)] dark:shadow-[inset_0_0_80px_rgba(0,0,0,0.2)]"
                >
                </div>
            </div>

            <!-- Technology Badges (Under Carousel) -->
            <div class="p-8 md:p-10">
                <h4
                    class="text-[10px] font-black uppercase tracking-[0.25em] opacity-30 mb-5"
                >
                    Tecnologías Empleadas
                </h4>
                <div id="modal-tech-badges" class="flex flex-wrap gap-3">
                    <!-- Badges will be injected here -->
                </div>
            </div>
        </div>

        <!-- Right Column: Content (40%) -->
        <div
            class="w-full md:w-2/5 p-8 md:p-12 flex flex-col border-t md:border-t-0 md:border-l border-border overflow-y-auto max-h-[50vh] md:max-h-full"
            style="background-color: var(--color-background);"
        >
            <div>
                <!-- Header -->
                <div class="mb-8">
                    <h2
                        id="modal-title"
                        class="text-3xl md:text-5xl font-black font-heading tracking-tighter mb-2 leading-tight"
                        style="color: #0088cc;"
                    >
                    </h2>
                    <div
                        id="modal-period"
                        class="text-xs font-bold tracking-widest uppercase opacity-40"
                    >
                    </div>
                </div>

                <!-- Description -->
                <div class="prose dark:prose-invert mb-10 max-w-none">
                    <p
                        id="modal-description-long"
                        class="text-base text-text/80 leading-relaxed font-medium"
                    >
                    </p>
                </div>
            </div>

            <!-- Footer: Links -->
            <div
                class="mt-auto border-t border-border pt-8 flex flex-col gap-4"
                id="modal-links"
            >
                <!-- Links will be injected here -->
            </div>
        </div>
    </div>
</div>

<script>
    import { gsap } from "gsap";
    import { projects } from "../../data/projects";

    let carouselTl: gsap.core.Timeline | null = null;
    const overlay = document.getElementById("project-modal-overlay");
    const backdrop = document.getElementById("modal-backdrop");
    const card = document.getElementById("modal-card");
    const closeBtn = document.getElementById("modal-close");

    function openModal(projectId: number) {
        const currentProject = projects.find((p) => p.id === projectId);
        if (!currentProject) return;

        // Reset Scroll position of content and card
        const contentArea = card?.querySelector(".md\\:w-2\\/5");
        if (contentArea) contentArea.scrollTop = 0;

        // Data Update
        document.getElementById("modal-title")!.innerText =
            currentProject.title;
        document.getElementById("modal-period")!.innerText =
            currentProject.periodo || "";
        document.getElementById("modal-description-long")!.innerText =
            currentProject.descripcionLarga || currentProject.description;

        // Render Badges
        const techContainer = document.getElementById("modal-tech-badges")!;
        techContainer.innerHTML = (currentProject.tecnologias || [])
            .map(
                (url) => `
            <img src="${url}" class="h-8 md:h-9 rounded-lg opacity-90 hover:opacity-100 hover:scale-105 hover:-rotate-1 transition-all cursor-default shadow-sm" />
        `,
            )
            .join("");

        // Render Links
        const linksContainer = document.getElementById("modal-links")!;
        linksContainer.innerHTML = (currentProject.links || [])
            .map(
                (link: any) => `
            <a href="${link.url}" target="_blank" class="flex items-center justify-between group p-4 rounded-2xl bg-primary/5 border border-border hover:bg-primary/10 hover:border-primary/30 transition-all no-underline">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-background flex items-center justify-center shadow-sm border border-border text-primary">
                        ${link.type === "github" ? '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>' : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>'}
                    </div>
                    <span class="text-sm font-bold text-text">
                        ${link.type === "github" ? "Ver en GitHub" : "Ver Demo en Vivo"}
                    </span>
                </div>
                <svg class="w-4 h-4 opacity-30 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </a>
        `,
            )
            .join("");

        // Carousel Inject
        const carousel = document.getElementById("modal-carousel")!;
        const dots = document.getElementById("modal-carousel-dots")!;
        const imgs = currentProject.imagenes?.length
            ? currentProject.imagenes
            : [currentProject.image];

        carousel.innerHTML = imgs
            .map(
                (img: string) => `
            <div class="min-w-full h-full flex-shrink-0">
                <img src="${img}" class="w-full h-full object-cover" />
            </div>
        `,
            )
            .join("");

        dots.innerHTML = imgs
            .map(
                (_: any, i: number) => `
            <button class="w-2 h-2 rounded-full bg-white/40 transition-all pointer-events-auto" data-slide="${i}"></button>
        `,
            )
            .join("");

        // Modal Entrance
        overlay?.classList.remove("hidden");
        gsap.to(backdrop!, { opacity: 1, duration: 0.4 });
        gsap.to(card!, {
            opacity: 1,
            scale: 1,
            y: 0,
            duration: 0.5,
            ease: "power4.out",
        });

        // Carousel Start
        startCarouselInfinite(imgs.length);
    }

    function startCarouselInfinite(count: number) {
        if (carouselTl) carouselTl.kill();
        if (count <= 1) return;

        const carousel = document.getElementById("modal-carousel")!;
        const dots = document.querySelectorAll("#modal-carousel-dots button");

        carouselTl = gsap.timeline({ repeat: -1 });

        // Reset dots
        dots.forEach((d) => d.classList.remove("w-6", "bg-white"));
        dots[0].classList.add("w-6", "bg-white");

        for (let i = 1; i <= count; i++) {
            carouselTl.to(carousel, {
                xPercent: -100 * (i % count),
                duration: 1.2,
                delay: 3.5,
                ease: "power3.inOut",
                onStart: () => {
                    const idx = i % count;
                    dots.forEach((d) => d.classList.remove("w-6", "bg-white"));
                    dots[idx].classList.add("w-6", "bg-white");
                },
            });
        }
    }

    function closeModal() {
        if (carouselTl) carouselTl.kill();
        gsap.to(card!, {
            opacity: 0,
            scale: 0.98,
            y: 10,
            duration: 0.3,
            ease: "power2.in",
        });
        gsap.to(backdrop!, {
            opacity: 0,
            duration: 0.3,
            onComplete: () => {
                overlay?.classList.add("hidden");
            },
        });
    }

    // Delegation
    document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const btn = target.closest(".project-btn-details");
        if (btn) {
            e.preventDefault();
            const id = parseInt(btn.getAttribute("data-project-id")!);
            openModal(id);
        }
    });

    closeBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);
</script>

<style>
    #modal-card {
        border-color: var(--color-border);
    }

    /* Custom Scrollbar for Right Side */
    .overflow-y-auto::-webkit-scrollbar {
        width: 3px;
    }
    .overflow-y-auto::-webkit-scrollbar-track {
        background: transparent;
    }
    .overflow-y-auto::-webkit-scrollbar-thumb {
        background: var(--color-primary);
        border-radius: 10px;
        opacity: 0.5;
    }

    #modal-carousel {
        will-change: transform;
    }

    #modal-carousel-dots button {
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .prose p {
        color: var(--color-text);
        opacity: 0.8;
    }
</style>
