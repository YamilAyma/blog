---
/**
 * ProjectsSlide - Sección de carrusel de proyectos.
 * Incluye: Fondo de código con efecto DOF (Blur), 
 * Carrusel horizontal suave, Cards animadas y puntos indicadores.
 * Ahora usa Content Collection y enlaza a páginas dedicadas.
 */
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<section
    id="projects"
    class="portfolio-slide w-full min-h-screen flex flex-col items-center justify-center p-6 relative overflow-hidden"
>
    <!-- Background Code Layer with DOF (Blur) Effect -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden bg-background">
        <div 
            class="absolute inset-0 opacity-20 dark:opacity-10 grayscale mix-blend-overlay scale-110 bg-cover bg-center"
            style="background-image: url('/images/portfolio/project-bg.png');"
        ></div>

        <div class="code-bg-overlay absolute inset-0 opacity-40 md:opacity-30">
        </div>
        <div class="absolute inset-x-0 top-0 h-1/4 bg-gradient-to-b from-background to-transparent z-10"></div>
        <div class="absolute inset-x-0 bottom-0 h-1/4 bg-gradient-to-t from-background to-transparent z-10"></div>
    </div>

    <div class="slide-content w-full max-w-7xl mx-auto z-10 py-10">
        <h2
            class="text-4xl md:text-6xl lg:text-7xl font-black font-heading tracking-tighter mb-8 text-center opacity-0 translate-y-10"
            id="projects-title"
            style="color: var(--md-h1);"
        >
            Mis Proyectos
        </h2>

        <!-- Projects Carousel Container -->
        <div class="relative w-full overflow-hidden" id="projects-carousel-wrapper">
            <!-- Left Arrow -->
            <button
                id="carousel-prev"
                class="carousel-arrow hidden md:flex absolute left-2 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full items-center justify-center border border-border shadow-lg transition-all hover:scale-110 active:scale-95"
                style="background-color: var(--color-background); color: var(--color-text);"
                aria-label="Proyecto anterior"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
            </button>

            <div 
                class="projects-carousel flex gap-4 md:gap-6 px-4 md:px-12 py-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide"
                id="projects-carousel"
            >
                {
                    projects.map((project) => (
                        <div
                            class="project-card flex-shrink-0 w-[260px] sm:w-[300px] md:w-[320px] bg-white/80 backdrop-blur-lg border border-text/10 rounded-[2.5rem] p-6 snap-center shadow-xl opacity-0 translate-y-20 flex flex-col items-center text-center group transition-all duration-500 hover:-translate-y-2 hover:border-primary/50"
                        >
                            <!-- Project Image -->
                            <div class="project-card-image w-full aspect-video rounded-[1.5rem] bg-stone-100 mb-6 flex items-center justify-center relative overflow-hidden group-hover:bg-stone-200 transition-colors border border-text/5">
                                <img 
                                    src={project.data.image} 
                                    alt={project.data.title}
                                    class="absolute inset-0 w-full h-full object-cover p-2"
                                    onerror="this.style.display='none';"
                                />
                            </div>
                            
                            <h3 class="text-xl md:text-2xl font-bold font-heading mb-3 text-text">{project.data.title}</h3>
                            <p class="text-xs md:text-sm text-text/70 mb-6 max-w-[240px] line-clamp-3 font-medium">
                                {project.data.description}
                            </p>
                            
                            <a 
                                href={`/projects/${project.id.replace(/\.(md|mdx)$/, "")}`}
                                class="px-6 py-2 rounded-full text-xs font-bold tracking-wide transition-all duration-300 hover:brightness-110 shadow-md active:scale-95 whitespace-nowrap inline-block no-underline"
                                style="background-color: var(--ui-nav-link); color: white;"
                            >
                                Ver Detalles
                            </a>
                        </div>
                    ))
                }
            </div>

            <!-- Right Arrow -->
            <button
                id="carousel-next"
                class="carousel-arrow hidden md:flex absolute right-2 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full items-center justify-center border border-border shadow-lg transition-all hover:scale-110 active:scale-95"
                style="background-color: var(--color-background); color: var(--color-text);"
                aria-label="Siguiente proyecto"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </button>
        </div>

        <!-- Carousel Indicators -->
        <div class="flex justify-center gap-2 mt-8 opacity-0 translate-y-10" id="projects-indicators">
            {
                projects.map((_, i) => (
                    <button 
                        class="w-2 h-2 rounded-full bg-text/20 transition-all duration-300 hover:bg-primary"
                        aria-label={`Ver proyecto ${i + 1}`}
                        data-index={i}
                    ></button>
                ))
            }
        </div>
    </div>
</section>

<script>
    const carousel = document.getElementById("projects-carousel");
    const prevBtn = document.getElementById("carousel-prev");
    const nextBtn = document.getElementById("carousel-next");

    if (carousel && prevBtn && nextBtn) {
        const scrollAmount = 340; // card width + gap

        prevBtn.addEventListener("click", () => {
            carousel.scrollBy({ left: -scrollAmount, behavior: "smooth" });
        });

        nextBtn.addEventListener("click", () => {
            carousel.scrollBy({ left: scrollAmount, behavior: "smooth" });
        });

        // Update arrow visibility based on scroll position
        function updateArrows() {
            const atStart = carousel!.scrollLeft <= 10;
            const atEnd = carousel!.scrollLeft + carousel!.clientWidth >= carousel!.scrollWidth - 10;
            prevBtn!.style.opacity = atStart ? "0.3" : "1";
            prevBtn!.style.pointerEvents = atStart ? "none" : "auto";
            nextBtn!.style.opacity = atEnd ? "0.3" : "1";
            nextBtn!.style.pointerEvents = atEnd ? "none" : "auto";
        }

        carousel.addEventListener("scroll", updateArrows);
        updateArrows();
    }
</script>

<style>
    .projects-carousel {
        -ms-overflow-style: none;
        scrollbar-width: none;
        scroll-behavior: smooth;
    }
    
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }

    /* Simulation of Code Background Pattern */
    .bg-code-pattern {
        background-image: 
            linear-gradient(90deg, transparent 5%, var(--md-h1) 5.5%, transparent 6%),
            linear-gradient(var(--color-bg) 0.5px, transparent 0.5px);
        background-size: 100px 30px;
        mask-image: linear-gradient(to right, black, transparent);
        filter: blur(20px);
    }

    @keyframes drift {
        from { transform: translateY(0); }
        to { transform: translateY(-50%); }
    }

    .animate-drift {
        animation: drift 60s linear infinite;
    }

    .dark .bg-code-pattern {
        filter: blur(15px) contrast(1.2) brightness(0.8);
    }

    .project-card {
        box-shadow: 0 30px 60px -15px rgba(0,0,0,0.08);
    }

    /* Dark mode card overrides */
    :global(.dark) .project-card {
        background-color: rgba(28, 25, 23, 0.85);
        border-color: rgba(255, 255, 255, 0.1);
    }

    :global(.dark) .project-card-image {
        background-color: rgba(41, 37, 36, 0.6);
        border-color: rgba(255, 255, 255, 0.05);
    }

    :global(.dark) .project-card:hover .project-card-image {
        background-color: rgba(68, 64, 60, 0.5);
    }
</style>
