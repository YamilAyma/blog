---
/**
 * ContactSlide - Sección de contacto del portafolio.
 * Incluye: Título "Conectemos", descripción, botones de Email y WhatsApp,
 * Ilustración SVG placeholder y fondo decorativo.
 */
import { SOCIALS } from "../../config";

const emailSocial = SOCIALS.find((s) => s.icon === "mail");
const emailHref = emailSocial?.href || "mailto:yamilaymadev@gmail.com";

// WhatsApp base link — personaliza con tu número
const whatsappNumber = "+51940750073";
const whatsappMessage = encodeURIComponent(
    "¡Hola Yamil! Vi tu portafolio y me gustaría conversar sobre un proyecto. 🚀",
);
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<section
    id="contact"
    class="portfolio-slide w-full flex flex-col items-center justify-center p-6 relative overflow-hidden"
>
    <!-- Background Decoration -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div
            class="absolute top-[20%] right-[10%] w-80 h-80 bg-primary/8 rounded-full blur-[100px]"
        >
        </div>
        <div
            class="absolute bottom-[15%] left-[5%] w-64 h-64 bg-accent/5 rounded-full blur-[80px]"
        >
        </div>
        <div
            class="absolute top-[50%] left-[40%] w-40 h-40 bg-primary/5 rounded-full blur-[60px]"
        >
        </div>
    </div>

    <!-- Main Content -->
    <div
        class="slide-content grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 lg:gap-16 items-center max-w-5xl mx-auto z-10 px-4 md:px-12 w-full"
    >
        <!-- Left Side: Text & Buttons -->
        <div
            class="flex flex-col items-center md:items-start text-center md:text-left order-2 md:order-1"
        >
            <!-- Title -->
            <h2
                class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-black font-heading tracking-tighter mb-3 opacity-0 translate-y-10 leading-none"
                id="contact-title"
                style="color: var(--md-h1);"
            >
                ¿Tienes un proyecto?
            </h2>

            <!-- Subtitle -->
            <h3
                class="text-xl sm:text-2xl md:text-3xl font-black font-heading mb-4 opacity-0 translate-y-10"
                id="contact-subtitle"
                style="color: #0088cc;"
            >
                Conectemos
            </h3>

            <!-- Description -->
            <p
                class="text-sm sm:text-base md:text-lg max-w-md mx-auto md:mx-0 opacity-0 translate-y-10 mb-8 text-text/80 leading-relaxed"
                id="contact-description"
            >
                Comparte tu visión conmigo. Estaré encantado de escuchar y
                colaborar en tu próximo proyecto.
            </p>

            <!-- Buttons -->
            <div
                class="flex flex-col sm:flex-row items-center gap-4 opacity-0 translate-y-10 w-full sm:w-auto"
                id="contact-buttons"
            >
                <!-- Email -->
                <a
                    href={emailHref}
                    class="contact-btn flex items-center justify-center gap-3 px-8 py-3.5 rounded-full text-sm font-bold tracking-wide transition-all duration-300 hover:brightness-110 hover:shadow-xl active:scale-95 shadow-lg w-full sm:w-auto"
                    style="background-color: var(--md-h1); color: white;"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path>
                    </svg>
                    Enviar Correo
                </a>

                <!-- WhatsApp -->
                <a
                    href={whatsappLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="contact-btn flex items-center justify-center gap-3 px-8 py-3.5 rounded-full text-sm font-bold tracking-wide transition-all duration-300 hover:brightness-110 hover:shadow-xl active:scale-95 shadow-lg w-full sm:w-auto"
                    style="background-color: #25D366; color: white;"
                >
                    <svg
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                        ></path>
                    </svg>
                    WhatsApp
                </a>
            </div>

            <!-- Social Links (Below buttons) -->
            <div
                class="flex items-center gap-5 mt-8 opacity-0 translate-y-10"
                id="contact-socials"
            >
                {
                    SOCIALS.filter((s) => s.icon !== "mail").map((social) => (
                        <a
                            href={social.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-text/40 hover:text-primary transition-all duration-300 hover:scale-125"
                            aria-label={social.name}
                        >
                            {social.icon === "github" && (
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                </svg>
                            )}
                            {social.icon === "linkedin" && (
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                                </svg>
                            )}
                            {social.icon === "pinterest" && (
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.411-5.97 1.411-5.97s-.36-.723-.36-1.781c0-1.667.967-2.912 2.168-2.912 1.024 0 1.517.769 1.517 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.008 2.352-1.497 3.146 1.122.341 2.308.526 3.54.526 6.615 0 12.019-5.373 12.019-12.018 0-6.645-5.374-12.017-12.02-12.017" />
                                </svg>
                            )}
                        </a>
                    ))
                }
            </div>
        </div>

        <!-- Right Side: SVG Illustration Placeholder (Desktop) -->
        <div
            class="flex justify-center order-1 md:order-2 opacity-0 scale-80"
            id="contact-visual"
        >
            <div
                class="relative w-[180px] h-[180px] sm:w-[200px] sm:h-[200px] md:w-[280px] md:h-[280px] lg:w-[400px] lg:h-[400px] flex items-center justify-center group"
            >
                <img
                    src="/images/portfolio/contact.png"
                    alt="Ilustración de contacto"
                    class="w-full h-full object-contain transition-all duration-700 group-hover:scale-105 drop-shadow-[0_20px_50px_rgba(0,0,0,0.1)]"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
            </div>
        </div>
    </div>
    <!-- Bottom Fade Gradient (Closing Effect) -->
    <div
        class="absolute inset-x-0 bottom-0 h-[30vh] z-20 pointer-events-none contact-fade-out"
    >
    </div>
</section>

<style>
    .portfolio-slide {
        background-color: transparent;
        min-height: 100vh;
    }

    .contact-btn {
        box-shadow: 0 8px 20px -4px rgba(0, 0, 0, 0.15);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .contact-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.2);
    }

    .contact-fade-out {
        background: linear-gradient(
            to bottom,
            transparent 0%,
            color-mix(in srgb, var(--color-background) 30%, white) 60%,
            color-mix(in srgb, var(--color-background) 50%, white) 100%
        );
    }

    :global(.dark) .contact-fade-out {
        background: linear-gradient(
            to bottom,
            transparent 0%,
            color-mix(in srgb, var(--color-background) 70%, black) 60%,
            color-mix(in srgb, var(--color-background) 90%, black) 100%
        );
    }
</style>
