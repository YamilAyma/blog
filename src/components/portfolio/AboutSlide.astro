<section
    id="about"
    class="portfolio-slide h-screen w-full flex flex-col items-center justify-center p-10 relative overflow-hidden bg-white/5"
>
    <div
        class="slide-content grid md:grid-cols-2 gap-12 items-center max-w-5xl"
    >
        <div class="about-text">
            <h2
                class="text-4xl md:text-6xl font-bold font-heading mb-6 opacity-0 -translate-x-10"
                id="about-title"
            >
                Sobre Mí
            </h2>
            <div
                class="space-y-4 text-lg opacity-0 -translate-x-10"
                id="about-description"
            >
                <p>
                    Soy un apasionado de la tecnología, la IA y el desarrollo de
                    software.
                </p>
                <p>
                    Mi enfoque es crear soluciones que no solo funcionen, sino
                    que también cautiven.
                </p>
            </div>
        </div>
        <div class="about-visual relative">
            <div
                class="w-full aspect-square bg-primary/10 rounded-2xl border-2 border-primary/20 flex items-center justify-center opacity-0 scale-90"
                id="about-box"
            >
                <span class="text-6xl">🚀</span>
            </div>
        </div>
    </div>
</section>
