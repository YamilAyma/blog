---
import { SITE } from "../../config";

interface Props {
    label?: string;
    image?: string;
}

const { 
    label = "Autor", 
    image = SITE.imgProfile || "https://avatars.githubusercontent.com/u/177412646?v=4" 
} = Astro.props;
---

<div class="flex items-center gap-3 pl-1 pr-5 py-1">
    <img 
        src={image} 
        alt={SITE.author} 
        class="w-10 h-10 rounded-full border-2 border-primary m-0"
    />
    <div class="flex flex-col text-left">
        <span class="text-sm font-bold leading-none">{SITE.author}</span>
        <span class="text-[10px] tracking-widest opacity-50 font-bold">{label}</span>
    </div>
</div>
