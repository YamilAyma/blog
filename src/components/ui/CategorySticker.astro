---
/**
 * CategorySticker - Muestra una imagen circular pequeña según la categoría del post.
 * Las rutas de imágenes se configuran en src/config/themes.ts
 */
import { CATEGORY_IMAGES } from "../../config/themes";
import { Image } from "astro:assets";

export interface Props {
    category: string;
}

const { category } = Astro.props;

// Obtener la imagen de la categoría o usar la por defecto
const imageSrc = CATEGORY_IMAGES[category] || CATEGORY_IMAGES["default"];
---

<div class="flex items-center">
    <Image
        src={imageSrc}
        alt={`Categoría: ${category}`}
        class="sticker w-1/6 h-1/6 rounded-full object-cover shadow-md border-[3px]"
        style="border-color: var(--color-accent);"
    />
</div>
