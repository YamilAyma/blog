---
import { getCollection, render } from "astro:content";
import Layout from "../../../../layouts/Layout.astro";
import Breadcrumbs from "../../../../components/Breadcrumbs.astro";
import AuthorBadge from "../../../../components/AuthorBadge.astro";
import FormattedDate from "../../../../components/FormattedDate.astro";
import ReadingTime from "../../../../components/ReadingTime.astro";
import TagBadge from "../../../../components/TagBadge.astro";
import OptimizedImage from "../../../../components/OptimizedImage.astro";

// Componentes especiales
import TLDR from "../../../../components/mdx/TLDR.astro";
import FAQs from "../../../../components/mdx/FAQs.astro";
import FAQItem from "../../../../components/mdx/FAQItem.astro";
import MDXImage from "../../../../components/mdx/MDXImage.astro";

export async function getStaticPaths() {
    const journalEntries = await getCollection("journal");

    return journalEntries.map((entry) => {
        const projectRef = entry.data.project;
        const projectSlug = typeof projectRef === 'string' 
            ? projectRef.replace(/\.(md|mdx)$/, "") 
            : projectRef.id.replace(/\.(md|mdx)$/, "");
        
        // El idPath sin extensión
        const idPath = entry.id.replace(/\.(md|mdx)$/, "");
        
        // El slug para Astro debe ser relativo a la base definida en el archivo (diario/)
        // Si el ID empieza con el nombre del proyecto, lo quitamos
        const entrySlug = idPath.startsWith(`${projectSlug}/`) 
            ? idPath.substring(projectSlug.length + 1) 
            : idPath;
        
        return {
            params: { 
                project: projectSlug,
                slug: entrySlug 
            },
            props: { entry },
        };
    });
}

const { entry } = Astro.props;
const { project, slug } = Astro.params;
const { Content, headings } = await render(entry);

// Obtener datos del proyecto para los breadcrumbs
const allProjects = await getCollection("projects");
const projectData = allProjects.find(p => p.id.replace(/\.(md|mdx)$/, "") === project);

const components = {
    TLDR,
    FAQs,
    FAQItem,
    img: MDXImage,
};
---

<Layout 
    title={`${entry.data.title} | Bitácora de ${projectData?.data.title || project}`}
    description={entry.data.description}
    image={entry.data.image}
>
    <article class="max-w-3xl mx-auto px-4 py-12 md:py-20">
        <Breadcrumbs 
            items={[
                { label: "Portafolio", href: "/portafolio" },
                { label: projectData?.data.title || project, href: `/proyectos/${project}` },
                { label: "Bitácora", href: `/proyectos/${project}#journal` },
                { label: entry.data.title }
            ]}
        />

        <header class="mt-10 mb-12 text-center md:text-left">
            <h1 class="text-4xl md:text-5xl font-black font-heading tracking-tight mb-6 leading-tight">
                {entry.data.title}
            </h1>
            
            {entry.data.description && (
                <p class="text-md md:text-md text-stone-600 dark:text-stone-300 font-medium leading-relaxed mb-6 italic opacity-90">
                    {entry.data.description}
                </p>
            )}

            <!-- Bloque de Autor y Metadata -->
            <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 mb-8">
                <AuthorBadge label="Autor del Proyecto" />

                <div class="flex items-center gap-4">
                    <FormattedDate date={entry.data.date} />
                    <ReadingTime content={entry.body || ""} />
                </div>
            </div>

            {entry.data.tags && entry.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-8 justify-center md:justify-start">
                    {entry.data.tags.map(tag => (
                        <TagBadge tag={tag} href={`/tags/${tag}`} />
                    ))}
                </div>
            )}
        </header>

        {entry.data.image && (
            <div class="mb-12 rounded-[2rem] overflow-hidden shadow-2xl aspect-video border border-black/5 dark:border-white/5">
                <OptimizedImage 
                    src={entry.data.image} 
                    alt={entry.data.title || ""}
                    class="w-full h-full object-cover"
                />
            </div>
        )}

        <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-heading prose-p:font-body journal-prose entry-content">
            <Content components={components} />
        </div>

        <footer class="mt-10 pt-10 border-t border-border/50 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs font-bold tracking-widest opacity-40">Volver al proyecto</p>
                    <a href={`/proyectos/${project}`} class="text-lg font-bold font-heading hover:text-primary transition-colors">
                        {projectData?.data.title || project}
                    </a>
                </div>
            </div>
        </footer>
    </article>
</Layout>

<style>
    @reference "../../../../styles/base.css";

    .journal-prose :global(h2) {
        @apply text-3xl font-black mt-12 mb-6;
    }
    .journal-prose :global(p) {
        @apply mb-6 leading-relaxed;
        color: color-mix(in srgb, var(--color-text) 80%, transparent);
    }
    .journal-prose :global(img) {
        @apply rounded-2xl shadow-lg my-8;
    }
</style>
