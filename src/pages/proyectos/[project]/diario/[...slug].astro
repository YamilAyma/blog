---
import { getCollection, render } from "astro:content";
import Layout from "../../../../layouts/Layout.astro";
import Breadcrumbs from "../../../../components/Breadcrumbs.astro";
import { format } from "date-fns";
import { es } from "date-fns/locale";
import AuthorBadge from "../../../../components/AuthorBadge.astro";

export async function getStaticPaths() {
    const journalEntries = await getCollection("journal");

    return journalEntries.map((entry) => {
        // En Astro 5+, si es una referencia, entry.data.project es un objeto con id y collection
        const projectRef = entry.data.project;
        const projectSlug = typeof projectRef === 'string' 
            ? projectRef.replace(/\.(md|mdx)$/, "") 
            : projectRef.id.replace(/\.(md|mdx)$/, "");
        
        const entrySlug = entry.id.split('/').pop()?.replace(/\.(md|mdx)$/, "");
        
        return {
            params: { 
                project: projectSlug,
                slug: entrySlug 
            },
            props: { entry },
        };
    });
}

const { entry } = Astro.props;
const { project, slug } = Astro.params;
const { Content, headings } = await render(entry);

// Calcular tiempo de lectura
const words = entry.body?.split(/\s+/).length || 0;
const readingTime = Math.ceil(words / 200);
const postDate = new Date(entry.data.date);

// Obtener datos del proyecto para los breadcrumbs
const allProjects = await getCollection("projects");
const projectData = allProjects.find(p => p.id.replace(/\.(md|mdx)$/, "") === project);
---

<Layout 
    title={`${entry.data.title} | Bitácora de ${projectData?.data.title || project}`}
    description={entry.data.description}
    image={entry.data.image}
>
    <article class="max-w-3xl mx-auto px-4 py-12 md:py-20">
        <Breadcrumbs 
            items={[
                { label: "Portafolio", href: "/portafolio" },
                { label: projectData?.data.title || project, href: `/proyectos/${project}` },
                { label: "Bitácora", href: `/proyectos/${project}#journal` },
                { label: entry.data.title }
            ]}
        />

        <header class="mt-10 mb-12 text-center md:text-left">
            <time class="text-xs font-bold uppercase tracking-[0.2em] text-primary/60 mb-4 block">
                {format(entry.data.date, "dd 'de' MMMM, yyyy", { locale: es })}
            </time>
            <h1 class="text-4xl md:text-5xl font-black font-heading tracking-tight mb-6 leading-tight">
                {entry.data.title}
            </h1>
            
            {entry.data.description && (
                <p class="text-md md:text-md text-stone-600 dark:text-stone-300 font-medium leading-relaxed mb-6 italic opacity-90">
                    {entry.data.description}
                </p>
            )}

            <!-- Bloque de Autor y Metadata -->
            <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 mb-8">
                <AuthorBadge label="Autor del Proyecto" />

                <div class="flex items-center gap-4 text-stone-500 dark:text-stone-400 text-xs font-bold uppercase tracking-widest">
                    <div class="flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                        <time datetime={postDate.toISOString()}>
                            {postDate.toLocaleDateString("es-ES", { dateStyle: "medium" })}
                        </time>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span>{readingTime} min lectura</span>
                    </div>
                </div>
            </div>

            {entry.data.tags && entry.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-8 justify-center md:justify-start">
                    {entry.data.tags.map(tag => (
                        <a href={`/tags/${tag}`} class="no-underline">
                            <span class="px-3 py-1 bg-primary/5 dark:bg-white/5 border border-primary/20 rounded-full text-md font-black tracking-widest text-primary hover:bg-primary/10 transition-colors">
                                #{tag}
                            </span>
                        </a>
                    ))}
                </div>
            )}
        </header>

        {entry.data.image && (
            <div class="mb-12 rounded-[2rem] overflow-hidden shadow-2xl aspect-video border border-black/5 dark:border-white/5">
                <img 
                    src={entry.data.image.src} 
                    alt={entry.data.title}
                    class="w-full h-full object-cover"
                />
            </div>
        )}

        <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-heading prose-p:font-body journal-prose entry-content">
            <Content />
        </div>

        <footer class="mt-10 pt-10 border-t border-border/50 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs font-bold tracking-widest opacity-40">Volver al proyecto</p>
                    <a href={`/proyectos/${project}`} class="text-lg font-bold font-heading hover:text-primary transition-colors">
                        {projectData?.data.title || project}
                    </a>
                </div>
            </div>
        </footer>
    </article>
</Layout>

<style>
    @reference "../../../../styles/base.css";

    .journal-prose :global(h2) {
        @apply text-3xl font-black mt-12 mb-6;
    }
    .journal-prose :global(p) {
        @apply mb-6 leading-relaxed;
        color: color-mix(in srgb, var(--color-text) 80%, transparent);
    }
    .journal-prose :global(img) {
        @apply rounded-2xl shadow-lg my-8;
    }
</style>
