---
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/blog/PostCard.astro";
import Breadcrumbs from "../../components/layout/Breadcrumbs.astro";
import { getSortedEntries } from "../../utils/collections";
import { SITE } from "../../config";

export async function getStaticPaths() {
    const allEntries = await getSortedEntries(["blog", "projects", "posts", "journal"]);
    const tags = [...new Set(allEntries.flatMap(entry => entry.data.tags || []))];

    return tags.map(tag => {
        const filteredEntries = allEntries.filter(entry => 
            entry.data.tags && entry.data.tags.includes(tag)
        );

        return {
            params: { tag },
            props: { entries: filteredEntries }
        };
    });
}

const { tag } = Astro.params;
const { entries } = Astro.props;
---

<Layout 
    title={`Contenido etiquetado como #${tag} — ${SITE.author}`}
    description={`Explora todos los artículos, proyectos y notas relacionados con ${tag}.`}
>
    <div class="mb-12">
        <Breadcrumbs 
            items={[
                { label: "Inicio", href: "/" },
                { label: "Etiquetas", href: "/tags" },
                { label: `#${tag}` }
            ]}
        />
    </div>

    <div class="mb-16">
        <h1 class="text-4xl md:text-6xl font-black font-heading tracking-tighter leading-tight mb-6">
            Tópico: <span class="text-primary italic">#{tag}</span>
        </h1>
        <p class="text-lg text-stone-500 dark:text-stone-400 max-w-2xl leading-relaxed">
            Se encontraron {entries.length} publicaciones relacionadas con este tema. 
            Explora el conocimiento y los proyectos asociados.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
        {entries.map(post => (
            <PostCard post={post} />
        ))}
    </div>

    <div class="rounded-[3rem] border border-black/5 dark:border-white/5">
        <h3 class="text-2xl font-bold font-heading mb-4 text-primary"></h3>
        <p class="text-stone-400 mb-8 max-w-md mx-auto small">
            Explora otros temas o vuelve al archivo general para ver todas las publicaciones.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
            <a href="/tags" class="px-8 py-3 bg-white rounded-2xl font-bold border border-black/5 dark:border-white/5 transition-all hover:shadow-lg transition-all text-md-h1">
                Ver todas las etiquetas
            </a>
            <a href="/blog" class="px-8 py-3 bg-md-h1 text-white rounded-2xl font-bold hover:shadow-lg hover:shadow-primary/20 transition-all">
                Ir al Blog
            </a>
        </div>
    </div>
</Layout>
