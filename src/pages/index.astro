---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import CategorySticker from "../components/CategorySticker.astro";

// Tarjetas
import cardPortafolio from "../assets/images/cards/portafolio.png";
import cardPost from "../assets/images/cards/post.png";
import cardProyectos from "../assets/images/cards/proyectos.png";
import cardRedes from "../assets/images/cards/redes.png";
const now = new Date();
const blogPosts = await getCollection("blog");
const journalEntries = (await getCollection("journal" as any)) as any[];

const posts = [...blogPosts, ...journalEntries]
	.filter((post) => {
		if (!post.data?.published) return false;
		if (post.data?.date > now) return false;
		return true;
	})
	.sort((a, b) => (b.data?.date?.valueOf() || 0) - (a.data?.date?.valueOf() || 0))
	.slice(0, 5);

import { SITE } from "../config";
import { Image } from "astro:assets";
---

<Layout title={SITE.title}>
	<section class="mb-16 mt-8">
		<h1 class="hero-title text-4xl md:text-4xl font-bold font-heading mb-6">
			{SITE.author}
		</h1>
		<div
			class="text-md max-w-2xl leading-relaxed space-y-4"
			style="color: var(--color-text);"
		>
			<p>
				¡Bienvenido! Este espacio es mi bitácora digital donde documento mis
				<strong>proyectos</strong>, tutoriales sobre diversos temas como <strong>Inteligencia
					Artificial, Automatización, Desarrollo y más</strong> asimismo guías prácticas sobre <strong>desarrollo
					de software</strong>.
			</p>
			<p>
				Fuera del mundo de los <strong>procesos y la
				automatización</strong>, me gusta explorar y aprender para tener una visión
				más amplia del mundo y conseguir que las personas con las que vivo y
				trabajo sean alegres, crezcan y aprendamos juntos.
			</p>
			<p>
				¡Espero que te vaya bien! 👋
			</p>
		</div>
	</section>

	<section class="mb-20">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12" id="nav-cards-grid">
			<a href="/portafolio" class="nav-card group block relative overflow-hidden rounded-[2.5rem] bg-white border-[6px] border-white shadow-xl hover:shadow-2xl transition-all duration-500">
				<Image 
					src={cardPortafolio} 
					alt="Portafolio" 
					class="w-full h-auto object-contain transition-transform duration-700"
				/>
			</a>
			<a href="/posts" class="nav-card group block relative overflow-hidden rounded-[2.5rem] bg-white border-[6px] border-white shadow-xl hover:shadow-2xl transition-all duration-500">
				<Image 
					src={cardPost} 
					alt="Posts Visuales" 
					class="w-full h-auto object-contain transition-transform duration-700"
				/>
			</a>
			<a href="/proyectos" class="nav-card group block relative overflow-hidden rounded-[2.5rem] bg-white border-[6px] border-white shadow-xl hover:shadow-2xl transition-all duration-500">
				<Image 
					src={cardProyectos} 
					alt="Proyectos" 
					class="w-full h-auto object-contain transition-transform duration-700"
				/>
			</a>
			<a href="/contacto" class="nav-card group block relative overflow-hidden rounded-[2.5rem] bg-white border-[6px] border-white shadow-xl hover:shadow-2xl transition-all duration-500">
				<Image 
					src={cardRedes} 
					alt="Redes y Contacto" 
					class="w-full h-auto object-contain transition-transform duration-700"
				/>
			</a>
		</div>
	</section>

	<section>
		<div
			class="flex items-center justify-between mb-6 pb-2 border-b border-black/10 dark:border-white/10"
		>
			<h2 class="hero-title text-2xl font-bold font-heading">
				Entradas Recientes
			</h2>
			<a href="/blog" class="text-sm font-medium nav-link hover:underline"
				>Explorar todos los artículos del blog &rarr;</a
			>
		</div>

		<ul class="space-y-2">
			{
				posts.map((post) => {
					const isJournal = "project" in post.data;
					const href = isJournal 
						? `/proyectos/${post.data.project}/diario/${post.id.split('/').pop()?.replace(/\.(md|mdx)$/, "")}`
						: `/blog/${post.id.replace(/\.(md|mdx)$/, "")}`;
					
					return (
						<li>
							<a
								href={href}
								class="blog-post-link group flex flex-col md:flex-row md:items-baseline md:justify-between py-2 px-3 -mx-3 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors"
							>
								<div class="flex flex-col">
									<span class="blog-post-title text-lg font-medium transition-colors">
										{post.data.title}
									</span>
									{isJournal && (
										<span class="text-[10px] font-black uppercase tracking-widest text-primary/60">
											Bitácora de Proyecto
										</span>
									)}
								</div>
								<span class="text-xs md:text-sm text-stone-400 font-mono whitespace-nowrap md:ml-4">
									{post.data.date.toLocaleDateString("es-ES", {
										year: "numeric",
										month: "short",
										day: "numeric",
										timeZone: "UTC",
									})}
								</span>
							</a>
						</li>
					);
				})
			}
		</ul>
	</section>
</Layout>

<script>
	import { gsap } from "gsap";

	const cards = document.querySelectorAll(".nav-card");
	
	if (cards.length > 0) {
		// Micro-interacción de hover suave
		cards.forEach(card => {
			card.addEventListener("mouseenter", () => {
				gsap.to(card, {
					y: -8,
					scale: 1.02,
					duration: 0.4,
					ease: "power2.out"
				});
			});
			card.addEventListener("mouseleave", () => {
				gsap.to(card, {
					y: 0,
					scale: 1,
					duration: 0.4,
					ease: "power2.inOut"
				});
			});
		});
	}
</script>
