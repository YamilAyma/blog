---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import NavigationCards from "../components/NavigationCards.astro";
import { SITE } from "../config";

const now = new Date();
const blogPosts = await getCollection("blog");
const journalEntries = (await getCollection("journal" as any)) as any[];

const posts = [...blogPosts, ...journalEntries]
	.filter((post) => {
		if (!post.data?.published) return false;
		if (post.data?.date > now) return false;
		return true;
	})
	.sort((a, b) => (b.data?.date?.valueOf() || 0) - (a.data?.date?.valueOf() || 0))
	.slice(0, 5);
---

<Layout title={SITE.title} showSidebar={true}>
	<section class="mb-16 mt-4">
		<h1 class="hero-title text-4xl md:text-4xl font-bold font-heading mb-6">
			{SITE.author}
		</h1>
		<div
			class="text-md max-w-2xl leading-relaxed space-y-4"
			style="color: var(--color-text);"
		>
			<p>
				¡Bienvenido! Este espacio es mi bitácora digital donde documento mis
				<strong>proyectos</strong>, tutoriales sobre diversos temas como <strong>Inteligencia
					Artificial, Automatización, Desarrollo y más</strong> asimismo guías prácticas sobre <strong>desarrollo
					de software</strong>.
			</p>
			<p>
				Fuera del mundo de los <strong>procesos y la
				automatización</strong>, me gusta explorar y aprender para tener una visión
				más amplia del mundo y conseguir que las personas con las que vivo y
				trabajo sean alegres, crezcan y aprendamos juntos.
			</p>
			<p>
				¡Espero que te vaya bien! 👋
			</p>
		</div>
	</section>
	<section class="mb-12">
		<div
			class="flex items-center justify-between mb-8 pb-3 border-b border-black/10 dark:border-white/10"
		>
			<h2 class="hero-title text-2xl font-bold font-heading">
				Entradas Recientes
			</h2>
			<a href="/blog" class="text-sm font-medium nav-link hover:underline"
				>Explorar todos &rarr;</a
			>
		</div>

		<ul class="space-y-4">
			{
				posts.map((post) => {
					const isJournal = "project" in post.data;
					const href = isJournal 
						? `/proyectos/${post.data.project}/diario/${post.id.split('/').pop()?.replace(/\.(md|mdx)$/, "")}`
						: `/blog/${post.id.replace(/\.(md|mdx)$/, "")}`;
					
					return (
						<li>
							<a
								href={href}
								class="blog-post-link group flex flex-col md:flex-row md:items-baseline md:justify-between py-3 px-4 -mx-4 rounded-2xl hover:bg-black/5 dark:hover:bg-white/5 transition-all duration-300"
							>
								<div class="flex flex-col gap-1">
									<span class="blog-post-title text-lg font-bold transition-colors">
										{post.data.title}
									</span>
									{isJournal && (
										<span class="text-[10px] font-black uppercase tracking-widest text-primary/60">
											Bitácora de Proyecto
										</span>
									)}
								</div>
								<span class="text-xs md:text-sm text-stone-400 font-mono whitespace-nowrap md:ml-4 mt-2 md:mt-0">
									{post.data.date.toLocaleDateString("es-ES", {
										year: "numeric",
										month: "short",
										day: "numeric",
										timeZone: "UTC",
									})}
								</span>
							</a>
						</li>
					);
				})
			}
		</ul>
	</section>

	<!-- Navegación solo visible en Mobile/Tablet al final para priorizar contenido -->
	<section class="lg:hidden mb-16 px-2">
		<NavigationCards />
	</section>
</Layout>
