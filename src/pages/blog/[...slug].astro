---
import { getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import TLDR from "../../components/mdx/TLDR.astro";
import FAQs from "../../components/mdx/FAQs.astro";
import FAQItem from "../../components/mdx/FAQItem.astro";
import MDXImage from "../../components/mdx/MDXImage.astro";
import Quote from "../../components/mdx/Quote.astro";
import References from "../../components/mdx/References.astro";
import CodeBlock from "../../components/mdx/CodeBlock.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
        props: { post },
    }));
}

const { post } = Astro.props;
const rendered = await render(post);
const { Content } = rendered;
const headings = rendered.headings;

const components = {
    TLDR,
    FAQs,
    FAQItem,
    Quote,
    Cita: Quote,
    Opinion: Quote,
    img: MDXImage,
    References,
    pre: CodeBlock,
};
---

<BlogPost frontmatter={post.data} headings={headings} content={post.body} id={post.id}>
    <Content components={components} />
</BlogPost>
