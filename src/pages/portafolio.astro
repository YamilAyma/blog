---
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
import IntroSlide from "../components/portfolio/IntroSlide.astro";
import AboutSlide from "../components/portfolio/AboutSlide.astro";
import ProjectsSlide from "../components/portfolio/ProjectsSlide.astro";
import ContactSlide from "../components/portfolio/ContactSlide.astro";
---

<PortfolioLayout title="Yamil | Portafolio">
    <main id="portfolio-container" class="relative">
        <IntroSlide />
        <AboutSlide />
        <ProjectsSlide />
        <ContactSlide />

        <!-- Navigation Sidebar (Desktop Only) -->
        <nav
            class="hidden md:flex fixed right-6 top-1/2 -translate-y-1/2 z-50 flex-col gap-6 items-end group"
        >
            {
                [
                    { id: "intro", label: "Inicio" },
                    { id: "about", label: "Sobre Mí" },
                    { id: "projects", label: "Proyectos" },
                    { id: "contact", label: "Contacto" },
                ].map((item) => (
                    <a
                        href={`#${item.id}`}
                        class="nav-dot-container flex items-center gap-4 group/item no-underline transition-all duration-300"
                        aria-label={`Ir a ${item.label}`}
                    >
                        <span
                            class="nav-label text-sm font-medium opacity-0 -translate-x-4 transition-all duration-300 group-hover/item:opacity-100 group-hover/item:translate-x-0"
                            style="color: var(--color-text);"
                        >
                            {item.label}
                        </span>
                        <div class="nav-dot w-3 h-3 rounded-full border border-primary transition-all duration-300 group-hover/item:scale-125" />
                    </a>
                ))
            }
        </nav>
    </main>
</PortfolioLayout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { ScrollToPlugin } from "gsap/ScrollToPlugin";

    if (typeof window !== "undefined") {
        gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

        // Initial setup for slides
        const slides = document.querySelectorAll(".portfolio-slide");
        const dotContainers = document.querySelectorAll(".nav-dot-container");
        const dots = document.querySelectorAll(".nav-dot");

        // Scrollytelling GSAP implementation
        slides.forEach((slide, i) => {
            const id = slide.id;

            // Update navigation dots based on active slide
            ScrollTrigger.create({
                trigger: slide,
                start: "top center",
                end: "bottom center",
                onToggle: (self) => {
                    if (self.isActive) {
                        // Update Right dots
                        dots.forEach((dot) =>
                            dot.classList.remove("bg-primary", "scale-125"),
                        );
                        dots[i]?.classList.add("bg-primary", "scale-125");

                        // Update Left Sidebar & Mobile Links
                        const sideLinks = document.querySelectorAll(
                            ".portfolio-side-link",
                        );
                        const mobileLinks = document.querySelectorAll(
                            ".portfolio-mobile-link",
                        );

                        sideLinks.forEach((link) =>
                            link.classList.remove("active", "text-primary"),
                        );
                        mobileLinks.forEach((link) =>
                            link.classList.remove("active", "text-primary"),
                        );

                        const activeSideLink = document.getElementById(
                            `side-link-${id}`,
                        );
                        activeSideLink?.classList.add("active", "text-primary");

                        // Find active mobile link by href
                        mobileLinks.forEach((link) => {
                            if (link.getAttribute("href") === `#${id}`) {
                                link.classList.add("active", "text-primary");
                            }
                        });
                    }
                },
            });

            // Intro Slide Entrance Sequence
            if (id === "intro") {
                const introTl = gsap.timeline({
                    delay: 0.5,
                    defaults: { ease: "power4.out", duration: 1.2 },
                });

                introTl
                    .to("#intro-profile", { opacity: 1, y: 0 })
                    .to("#intro-name", { opacity: 1, y: 0 }, "-=0.8")
                    .to("#intro-role", { opacity: 1, y: 0 }, "-=1")
                    .to("#intro-description", { opacity: 1, y: 0 }, "-=1")
                    .to("#intro-cta", { opacity: 1, y: 0, scale: 1 }, "-=0.9")
                    .to("#intro-socials", { opacity: 1, y: 0 }, "-=0.8");
            }

            // About Slide Entrance Sequence
            if (id === "about") {
                const aboutTl = gsap.timeline({
                    scrollTrigger: {
                        trigger: slide,
                        start: "top 60%",
                    },
                    defaults: { ease: "power3.out", duration: 1 },
                });

                aboutTl
                    .to("#about-title", { opacity: 1, x: 0 })
                    .to("#about-description", { opacity: 1, x: 0 }, "-=0.7")
                    .to("#about-cv-mobile", { opacity: 1, y: 0 }, "-=0.7")
                    .to("#about-visual-box", { opacity: 1, scale: 1 }, "-=0.8")
                    .to(
                        "#about-cv-desktop",
                        { opacity: 1, y: 0, from: { y: 20 } },
                        "-=0.7",
                    );
            }

            // Projects Slide Entrance Sequence
            if (id === "projects") {
                const projectsTl = gsap.timeline({
                    scrollTrigger: {
                        trigger: slide,
                        start: "top 60%",
                    },
                    defaults: { ease: "power3.out", duration: 1 },
                });

                projectsTl
                    .to("#projects-title", { opacity: 1, y: 0 })
                    .to(
                        ".project-card",
                        {
                            opacity: 1,
                            y: 0,
                            stagger: 0.15,
                            duration: 1.2,
                            ease: "back.out(1.2)",
                        },
                        "-=0.7",
                    )
                    .to("#projects-indicators", { opacity: 1, y: 0 }, "-=1");
            }

            // Contact Slide Entrance Sequence
            if (id === "contact") {
                const contactTl = gsap.timeline({
                    scrollTrigger: {
                        trigger: slide,
                        start: "top 60%",
                    },
                    defaults: { ease: "power3.out", duration: 1 },
                });

                contactTl
                    .to("#contact-visual", { opacity: 1, scale: 1 })
                    .to("#contact-title", { opacity: 1, y: 0 }, "-=0.7")
                    .to("#contact-subtitle", { opacity: 1, y: 0 }, "-=0.8")
                    .to("#contact-description", { opacity: 1, y: 0 }, "-=0.8")
                    .to(
                        "#contact-buttons",
                        { opacity: 1, y: 0, ease: "back.out(1.2)" },
                        "-=0.7",
                    )
                    .to("#contact-socials", { opacity: 1, y: 0 }, "-=0.7");
            }
        });

        // Smooth scroll for nav dots
        const sideLinks = document.querySelectorAll(".portfolio-side-link");
        const mobileLinks = document.querySelectorAll(".portfolio-mobile-link");
        [...dotContainers, ...sideLinks, ...mobileLinks].forEach((link) => {
            link.addEventListener("click", (e) => {
                e.preventDefault();
                const id = link.getAttribute("href")?.substring(1);
                const target = document.getElementById(id!);
                if (target) {
                    gsap.to(window, {
                        scrollTo: target.offsetTop,
                        duration: 1,
                        ease: "power3.inOut",
                    });
                }
            });
        });

        // Keyboard Navigation (Accessibility)
        window.addEventListener("keydown", (e) => {
            const currentSlideIndex = Array.from(slides).findIndex((s) => {
                const rect = s.getBoundingClientRect();
                return rect.top >= -10 && rect.top <= 10;
            });

            if (
                e.key === "ArrowDown" ||
                e.key === "ArrowRight" ||
                e.key === "PageDown"
            ) {
                if (currentSlideIndex < slides.length - 1) {
                    e.preventDefault();
                    const nextTarget = slides[
                        currentSlideIndex + 1
                    ] as HTMLElement;
                    gsap.to(window, {
                        scrollTo: nextTarget.offsetTop,
                        duration: 0.8,
                        ease: "power2.inOut",
                    });
                }
            } else if (
                e.key === "ArrowUp" ||
                e.key === "ArrowLeft" ||
                e.key === "PageUp"
            ) {
                if (currentSlideIndex > 0) {
                    e.preventDefault();
                    const prevTarget = slides[
                        currentSlideIndex - 1
                    ] as HTMLElement;
                    gsap.to(window, {
                        scrollTo: prevTarget.offsetTop,
                        duration: 0.8,
                        ease: "power2.inOut",
                    });
                }
            } else if (e.key === "Home") {
                e.preventDefault();
                gsap.to(window, {
                    scrollTo: 0,
                    duration: 1,
                    ease: "power3.inOut",
                });
            } else if (e.key === "End") {
                e.preventDefault();
                const lastTarget = slides[slides.length - 1] as HTMLElement;
                gsap.to(window, {
                    scrollTo: lastTarget.offsetTop,
                    duration: 1,
                    ease: "power3.inOut",
                });
            }
        });
        // Mouse Wheel Navigation (Scroll Snapping with GSAP)
        let isScrolling = false;
        window.addEventListener(
            "wheel",
            (e) => {
                if (isScrolling) return;

                const currentSlideIndex = Array.from(slides).findIndex((s) => {
                    const rect = s.getBoundingClientRect();
                    return rect.top >= -10 && rect.top <= 10;
                });

                if (e.deltaY > 0) {
                    // Scroll Down
                    if (currentSlideIndex < slides.length - 1) {
                        isScrolling = true;
                        const nextTarget = slides[
                            currentSlideIndex + 1
                        ] as HTMLElement;
                        gsap.to(window, {
                            scrollTo: nextTarget.offsetTop,
                            duration: 1,
                            ease: "power2.inOut",
                            onComplete: () => {
                                setTimeout(() => (isScrolling = false), 500);
                            },
                        });
                    }
                } else if (e.deltaY < 0) {
                    // Scroll Up
                    if (currentSlideIndex > 0) {
                        isScrolling = true;
                        const prevTarget = slides[
                            currentSlideIndex - 1
                        ] as HTMLElement;
                        gsap.to(window, {
                            scrollTo: prevTarget.offsetTop,
                            duration: 1,
                            ease: "power2.inOut",
                            onComplete: () => {
                                setTimeout(() => (isScrolling = false), 500);
                            },
                        });
                    }
                }
            },
            { passive: false },
        );
    }
</script>

<style>
    main {
        background-color: var(--color-background);
    }
    .nav-dot {
        background-color: transparent;
        border-color: var(--color-primary);
    }
    .nav-dot.bg-primary {
        background-color: var(--color-primary);
    }
</style>
